@model IEnumerable<TablicaOgloszen.Models.Post>

@{
	ViewData["Title"] = "Posts";
}

<div class="mt-3">
    @if (ViewBag.CurrentPage > 1)
    {
        <a asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)" class="btn btn-primary">Previous</a>
    }

    <span>Page @ViewBag.CurrentPage</span>

    <a asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)" class="btn btn-primary">Next</a>
</div>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Title)
            </th>
            <th> @Html.DisplayNameFor(model => model.Date)</th>
			<th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Title)
                </td>
                <td>
					@Html.DisplayFor(modelItem => item.Date)
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>